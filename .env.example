# Any OpenAI-compatible endpoint. Examples:
#   9router:  http://localhost:8787/v1
#   OpenAI:   https://api.openai.com/v1
#   Together: https://api.together.xyz/v1
#   vLLM:     http://localhost:8000/v1
#   Ollama:   http://localhost:11434/v1
export OPENAI_BASE_URL="http://localhost:8787/v1"
export OPENAI_API_KEY="sk-..."

# Single model used for both target and optimizer unless overridden by config / CLI.
export OPENAI_MODEL="gpt-5.5"

# Optional: separate models for target rollouts vs optimizer reflection.
# export OPENAI_TARGET_MODEL="gpt-5.4-mini"
# export OPENAI_OPTIMIZER_MODEL="gpt-5.5"

# Optional knobs
# export OPENAI_TIMEOUT_SECS="120"
# export OPENAI_MAX_RETRIES="4"
